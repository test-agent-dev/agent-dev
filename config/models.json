{
  "models": {
    "gpt-4.1-azure": {
      "provider": "openai",
      "model_id": "${AZURE_OPENAI_DEPLOYMENT}",
      "api_key": "${AZURE_OPENAI_API_KEY}",
      "api_base": "${AZURE_OPENAI_ENDPOINT}",
      "api_version": "${AZURE_OPENAI_API_VERSION}",
      "max_tokens": 4000,
      "temperature": 0.7,
      "context_window": 128000,
      "enabled": true,
      "instructions": "You are a helpful AI assistant using Azure OpenAI GPT-4.1.",
      "custom_parameters": {
        "api-version": "${AZURE_OPENAI_API_VERSION}"
      }
    },
    "gpt-4": {
      "provider": "openai",
      "model_id": "gpt-4",
      "api_key": "${OPENAI_API_KEY}",
      "max_tokens": 4000,
      "temperature": 0.7,
      "context_window": 8192,
      "enabled": true,
      "instructions": "You are a helpful AI assistant.",
      "custom_parameters": {}
    },
    "gpt-3.5-turbo": {
      "provider": "openai", 
      "model_id": "gpt-3.5-turbo",
      "api_key": "${OPENAI_API_KEY}",
      "max_tokens": 4000,
      "temperature": 0.7,
      "context_window": 4096,
      "enabled": true,
      "instructions": "You are a helpful AI assistant.",
      "custom_parameters": {}
    },
    "claude-3-sonnet": {
      "provider": "anthropic",
      "model_id": "claude-3-sonnet-20240229",
      "api_key": "${ANTHROPIC_API_KEY}",
      "max_tokens": 4000,
      "temperature": 0.7,
      "context_window": 200000,
      "enabled": false,
      "instructions": "You are Claude, an AI assistant created by Anthropic.",
      "custom_parameters": {}
    },
    "claude-3-opus": {
      "provider": "anthropic",
      "model_id": "claude-3-opus-20240229", 
      "api_key": "${ANTHROPIC_API_KEY}",
      "max_tokens": 4000,
      "temperature": 0.7,
      "context_window": 200000,
      "enabled": false,
      "instructions": "You are Claude, an AI assistant created by Anthropic.",
      "custom_parameters": {}
    },
    "mixtral-8x7b": {
      "provider": "huggingface",
      "model_id": "mistralai/Mixtral-8x7B-Instruct-v0.1",
      "max_tokens": 2000,
      "temperature": 0.7,
      "context_window": 32768,
      "enabled": false,
      "instructions": "You are Mixtral, a helpful AI assistant.",
      "custom_parameters": {
        "do_sample": true,
        "top_p": 0.9
      }
    },
    "custom-local": {
      "provider": "custom",
      "model_id": "local-model",
      "api_base": "http://localhost:11434/v1",
      "max_tokens": 2000,
      "temperature": 0.7,
      "context_window": 4096,
      "enabled": false,
      "instructions": "You are a local AI assistant.",
      "custom_parameters": {}
    }
  }
}
